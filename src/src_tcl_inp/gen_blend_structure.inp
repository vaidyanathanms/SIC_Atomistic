tolerance 2.0
filetype pdb
output ../../InputStructures/combined/li_peo_vecmtfsi_blend.pdb

# PEO layer: 20 molecules
structure ../../InputStructures/inpcoord_files/peo_polymer/100PEO_Optimized.pdb
  number 20
  inside box 0. 0. 5.0  110. 110. 125.0
end structure

# VEC-STFSI Polymer: 100 molecules
structure ../../InputStructures/inpcoord_files/vecmtfsi_polymer/modified.pdb
  number 100
  inside box 0. 0. 122.0  110. 110. 300.0
end structure

# Li atoms: 500 
structure ../../InputStructures/inpcoord_files/li_atom/Li_Atom.pdb
  number 500
  inside box 0. 0. 125.0 110. 110. 290.0
end structure

